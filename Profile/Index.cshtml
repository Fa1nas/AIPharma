@model AIPharma.Models.User

@{
    ViewData["Title"] = "Особистий кабінет";
}

<section class="page-header">
    <h1>Особистий кабінет</h1>
    <p>Вітаємо, @Model.FullName!</p>
</section>

<section class="profile-grid">
    <div class="profile-card">
        <h3>Дані користувача</h3>
        <p><strong>ПІБ:</strong> @Model.FullName</p>
        <p><strong>Email:</strong> @Model.Email</p>
        <p><strong>Роль:</strong> @Model.Role?.Name</p>
        <p><strong>Дата реєстрації:</strong> @Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</p>
    </div>

    <div class="profile-card">
        <h3>Активність</h3>
        <p><strong>Замовлень:</strong> @Model.Orders.Count</p>
        <p><strong>Обраних товарів:</strong> @Model.Favorites.Count</p>
        <p><strong>AI-сесій:</strong> @Model.ChatSessions.Count</p>
    </div>

    <div class="profile-card">
        <h3>Швидкі дії</h3>
        <div class="vertical-actions">
            <a class="btn-secondary" asp-controller="Chat" asp-action="Index">AI-помічник</a>
            <a class="btn-secondary" asp-controller="Products" asp-action="Index">Перейти до каталогу</a>
            <a class="btn-secondary" asp-controller="Orders" asp-action="Index">Мої замовлення</a>
            <a class="btn-secondary" asp-controller="Complaints" asp-action="Index">Мої звернення</a>
            <a class="btn-secondary" asp-controller="Profile" asp-action="Favorites">Обрані товари</a>
            <a class="btn-secondary" asp-controller="Profile" asp-action="Compare">Порівняння товарів</a>
        </div>
    </div>
</section>

<section class="note-section">
    <h2>Мої останні замовлення</h2>

    @if (Model.Orders.Any())
    {
        <table class="data-table">
            <thead>
                <tr>
                    <th>№</th>
                    <th>Аптека</th>
                    <th>Статус</th>
                    <th>Сума</th>
                    <th>Дата</th>
                    <th>Дії</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model.Orders.OrderByDescending(o => o.CreatedAt).Take(5))
                {
                    <tr>
                        <td>@order.Id</td>
                        <td>@order.Pharmacy?.Name</td>
                        <td>@order.Status</td>
                        <td>@order.TotalAmount грн</td>
                        <td>@order.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                        <td>
                            <a class="btn-small" asp-controller="Orders" asp-action="Details" asp-route-id="@order.Id">
                                Деталі
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p>Поки що у вас немає замовлень.</p>
    }
</section>