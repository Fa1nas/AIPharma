@model List<AIPharma.Models.ProductStock>

@{
    ViewData["Title"] = "Склад аптеки";
}

<section class="page-header">
    <h1>Склад аптеки</h1>
    <p>Менеджер може змінювати кількість товарів тільки у своїй аптеці.</p>
</section>

<table class="data-table">
    <thead>
        <tr>
            <th>Товар</th>
            <th>Категорія</th>
            <th>Ціна</th>
            <th>Поточна кількість</th>
            <th>Нова кількість</th>
            <th>Дія</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var stock in Model)
        {
            <tr>
                <td>@stock.Product?.Name</td>
                <td>@stock.Product?.ProductCategory?.Name</td>
                <td>@stock.Product?.Price грн</td>
                <td>@stock.Quantity</td>
                <td>
                    <form asp-controller="Manager" asp-action="UpdateStock" method="post" class="order-form">
                        <input type="hidden" name="stockId" value="@stock.Id" />
                        <input type="number" name="quantity" value="@stock.Quantity" min="0" class="quantity-input" />
                        <button type="submit" class="btn-small order-btn">Зберегти</button>
                    </form>
                </td>
                <td>
                    <a class="btn-small" asp-controller="Products" asp-action="Details" asp-route-id="@stock.ProductId">
                        Перегляд
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>