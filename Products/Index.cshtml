@model List<AIPharma.Models.Product>

@{
    ViewData["Title"] = "Каталог товарів";
    var categories = ViewBag.Categories as List<AIPharma.Models.ProductCategory>;
}

<section class="page-header">
    <h1>Каталог товарів AIPharma</h1>
    <p>Переглядайте товари, ціни, знижки та наявність у різних аптеках міста.</p>
</section>

<form method="get" class="filter-panel advanced-filter">
    <input type="text" name="search" value="@ViewBag.Search" placeholder="Пошук товару, виробника або опису..." />

    <select name="categoryId">
        <option value="">Усі категорії</option>
        @foreach (var category in categories ?? new List<AIPharma.Models.ProductCategory>())
        {
            if (ViewBag.CategoryId == category.Id)
            {
                <option value="@category.Id" selected>@category.Name</option>
            }
            else
            {
                <option value="@category.Id">@category.Name</option>
            }
        }
    </select>

    <input type="number" name="minPrice" value="@ViewBag.MinPrice" placeholder="Ціна від" min="0" step="1" />
    <input type="number" name="maxPrice" value="@ViewBag.MaxPrice" placeholder="Ціна до" min="0" step="1" />

    <button type="submit">Знайти</button>
</form>

<div class="product-grid">
    @foreach (var product in Model)
    {
        var totalQuantity = product.ProductStocks.Sum(s => s.Quantity);
        var actualPrice = product.DiscountPrice ?? product.Price;

        <div class="product-card">
            <div class="product-image-box">
                <img src="@product.ImagePath"
                     alt="@product.Name"
                     referrerpolicy="no-referrer"
                     onerror="this.src='/images/products/default.png'" />
            </div>

            <h3>@product.Name</h3>

            <p class="category">@product.ProductCategory?.Name</p>
            <p class="manufacturer">@product.Manufacturer</p>

            <p class="description">
                @(product.Description.Length > 120 ? product.Description.Substring(0, 120) + "..." : product.Description)
            </p>

            <div class="price-block">
                @if (product.DiscountPrice != null)
                {
                    <span class="old-price">@product.Price грн</span>
                    <span class="discount-price">@product.DiscountPrice грн</span>
                }
                else
                {
                    <span class="price">@product.Price грн</span>
                }
            </div>

            <p class="stock">Загальна наявність: @totalQuantity шт.</p>

            @if (product.IsPrescriptionRequired)
            {
                <p class="warning">Рецептурний товар</p>
            }

            <a class="btn-primary" asp-controller="Products" asp-action="Details" asp-route-id="@product.Id">
                Детальніше
            </a>
        </div>
    }
</div>