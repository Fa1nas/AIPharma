@model List<AIPharma.Models.Complaint>

@{
    ViewData["Title"] = "Усі звернення";
}

<section class="page-header">
    <h1>Усі звернення користувачів</h1>
    <p>Список скарг і звернень щодо роботи аптек мережі AIPharma.</p>
</section>

@if (!Model.Any())
{
    <div class="note-section">
        <p>Звернень поки що немає.</p>
    </div>
}
else
{
    <table class="data-table">
        <thead>
            <tr>
                <th>№</th>
                <th>Користувач</th>
                <th>Аптека</th>
                <th>Тема</th>
                <th>Статус</th>
                <th>Дата</th>
                <th>Дії</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var complaint in Model)
            {
                <tr>
                    <td>@complaint.Id</td>
                    <td>@complaint.User?.FullName</td>
                    <td>@complaint.Pharmacy?.Name</td>
                    <td>@complaint.Title</td>
                    <td>@complaint.Status</td>
                    <td>@complaint.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>
                        <a class="btn-small" asp-controller="Admin" asp-action="ComplaintDetails" asp-route-id="@complaint.Id">
                            Деталі
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}