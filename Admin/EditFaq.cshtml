@model AIPharma.Models.FaqAnswer

@{
    ViewData["Title"] = "Редагувати FAQ";
}

<section class="page-header">
    <h1>Редагувати FAQ-відповідь</h1>
    <p>Зміна універсального питання та відповіді для AI-помічника.</p>
</section>

<section class="form-section">
    <div class="form-card">
        @if (ViewBag.Error != null)
        {
            <div class="error-message">@ViewBag.Error</div>
        }

        <form method="post">
            <input type="hidden" name="id" value="@Model.Id" />

            <label>Категорія</label>
            <input type="text" name="category" value="@Model.Category" />

            <label>Питання</label>
            <input type="text" name="question" value="@Model.Question" />

            <label>Відповідь</label>
            <textarea name="answer" rows="7">@Model.Answer</textarea>

            <button type="submit" class="btn-primary">Зберегти зміни</button>
        </form>
    </div>
</section>