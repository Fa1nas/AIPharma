@model List<AIPharma.Models.Order>

@{
    ViewData["Title"] = "Усі замовлення";
}

<section class="page-header">
    <h1>Усі замовлення</h1>
    <p>Перелік замовлень користувачів у мережі аптек AIPharma.</p>
</section>

@if (!Model.Any())
{
    <div class="note-section">
        <p>Замовлень поки що немає.</p>
    </div>
}
else
{
    <table class="data-table">
        <thead>
            <tr>
                <th>№</th>
                <th>Користувач</th>
                <th>Аптека</th>
                <th>Товарів</th>
                <th>Сума</th>
                <th>Статус</th>
                <th>Дата</th>
                <th>Дії</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var order in Model)
            {
                <tr>
                    <td>@order.Id</td>
                    <td>@order.User?.FullName</td>
                    <td>@order.Pharmacy?.Name</td>
                    <td>@order.Items.Sum(i => i.Quantity)</td>
                    <td>@order.TotalAmount грн</td>
                    <td>@order.Status</td>
                    <td>@order.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>
                        <a class="btn-small" asp-controller="Admin" asp-action="OrderDetails" asp-route-id="@order.Id">
                            Деталі
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}