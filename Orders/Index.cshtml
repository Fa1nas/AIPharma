@model List<AIPharma.Models.Order>

@{
    ViewData["Title"] = "Мої замовлення";
}

<section class="page-header">
    <h1>Мої замовлення</h1>
    <p>Список замовлень, оформлених користувачем у мережі аптек AIPharma.</p>
</section>

@if (!Model.Any())
{
    <div class="note-section">
        <p>У вас поки що немає замовлень.</p>
        <a class="btn-primary" asp-controller="Products" asp-action="Index">Перейти до каталогу</a>
    </div>
}
else
{
    <table class="data-table">
        <thead>
            <tr>
                <th>№</th>
                <th>Аптека</th>
                <th>Кількість товарів</th>
                <th>Сума</th>
                <th>Оплата</th>
                <th>Статус</th>
                <th>Дата</th>
                <th>Дії</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var order in Model)
            {
                <tr>
                    <td>@order.Id</td>
                    <td>@order.Pharmacy?.Name</td>
                    <td>@order.Items.Sum(i => i.Quantity)</td>
                    <td>@order.TotalAmount грн</td>
                    <td>@order.PaymentType</td>
                    <td>@order.Status</td>
                    <td>@order.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>
                        <a class="btn-small" asp-controller="Orders" asp-action="Details" asp-route-id="@order.Id">
                            Деталі
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}